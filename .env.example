# MongoDB (Atlas or local)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=goaltracker

# Auth.js / NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-long-random-string

# Public URL in production (optional; Auth.js trustHost is enabled)
# AUTH_URL=https://your-cloud-run-url.run.app
